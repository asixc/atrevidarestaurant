---
import BaseLayout from '@/layouts/BaseLayout.astro';

const team = [
  {
    name: 'Marc',
    role: 'Co-fundador · Sabadell',
    origin: 'Sabadell',
    bio: 'Nascut a Sabadell, Marc és qui va posar la llavor del projecte quan va heretar la casa familiar de la seva estimada àvia Dominga. Allò que va néixer com un somni —reformar aquelles parets plenes de records per obrir-hi un restaurant— avui és una realitat.',
    image: '/images/equip-marc.jpg',
    alt: 'Imatge representativa de Marc, co-fundador d\'Atrevida',
  },
  {
    name: 'Héctor',
    role: 'Xef · Sant Antoni de Vilamajor',
    origin: 'Sant Antoni de Vilamajor',
    bio: 'La cuina de l\'Héctor és el cor d\'Atrevida. Gendre d\'Emili i parella de la Sheila, porta anys cuinant al restaurant familiar de Sant Antoni. La seva aposta: cuina tradicional amb un toc atrevit i modern, sempre partint del producte local.',
    image: '/images/equip-hector.jpg',
    alt: 'Imatge representativa d\'Héctor, xef d\'Atrevida',
  },
  {
    name: 'Sheila',
    role: 'Sala · Sant Antoni de Vilamajor',
    origin: 'Sant Antoni de Vilamajor',
    bio: 'Filla d\'Emili i parella d\'Héctor, la Sheila és l\'ànima de la sala. Ha crescut envoltada de gastronomia al restaurant familiar de Sant Antoni i porta a l\'Atrevida la calidesa d\'una acollida autèntica.',
    image: '/images/equip-sheila.jpg',
    alt: 'Imatge representativa de Sheila, sala d\'Atrevida',
  },
  {
    name: 'Emili',
    role: 'Co-fundador · Sant Antoni de Vilamajor',
    origin: 'Sant Antoni de Vilamajor',
    bio: 'Sogre d\'Héctor i pare de la Sheila, l\'Emili és la pedra angular del projecte. Amb dècades d\'experiència al restaurant de Sant Antoni de Vilamajor, aporta el saber fer d\'una vida dedicada a la cuina.',
    image: '/images/equip-emiliv2.jpg',
    alt: 'Imatge representativa d\'Emili, co-fundador d\'Atrevida',
  },
];
---

<BaseLayout
  title="Qui Som — Atrevida Restaurant"
  description="Coneix l'equip darrere d'Atrevida: Marc, Héctor, Sheila i Emili. Quatre persones unides per la passió per la cuina i l'amistat."
  activeRoute="equip"
>
  <div class="pt-16 md:pt-20 pb-24 md:pb-32">

    <!-- Page header -->
    <header class="px-6 pt-16 md:pt-24 pb-16 max-w-6xl mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] text-primary mb-3">L'equip</p>
      <h1 class="font-headline text-5xl md:text-7xl text-on-surface tracking-tight">
        Qui som
      </h1>
      <p class="text-on-surface/60 mt-6 max-w-2xl text-base md:text-xl leading-relaxed">
        Quatre persones, dues ciutats, una passió. L'Atrevida neix de l'amistat entre dues famílies
        unides per la cuina, i la convicció que el menjar és una manera de cuidar-se.
      </p>
    </header>

    <!-- Team cards -->
    <section class="px-6 max-w-6xl mx-auto" aria-label="Membres de l'equip">
      <ul class="space-y-6 md:space-y-8" role="list">
        {team.map((member, i) => (
          <li>
            <article
              class:list={[
                'grid grid-cols-1 md:grid-cols-2 gap-0 rounded-3xl overflow-hidden bg-surface-container-high',
                i % 2 === 1 ? 'md:[&>:first-child]:order-2' : '',
              ]}
            >
              <!-- Image -->
              <div class="aspect-[4/3] md:aspect-auto md:min-h-[400px] overflow-hidden">
                <img
                  src={member.image}
                  alt={member.alt}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>

              <!-- Content -->
              <div class="p-8 md:p-12 flex flex-col justify-center">
                <p class="text-xs uppercase tracking-[0.3em] text-primary mb-2">{member.origin}</p>
                <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-1">{member.name}</h2>
                <p class="text-outline text-sm uppercase tracking-widest mb-6">{member.role}</p>
                <p class="text-on-surface/70 text-base md:text-lg leading-relaxed">{member.bio}</p>
              </div>
            </article>
          </li>
        ))}
      </ul>
    </section>

    <!-- Quote final -->
    <section class="px-6 py-20 md:py-28 text-center max-w-3xl mx-auto" aria-label="Frase de l'equip">
      <span class="material-symbols-outlined text-primary text-5xl mb-6 block" aria-hidden="true">format_quote</span>
      <blockquote>
        <p class="font-headline italic text-3xl md:text-4xl text-on-surface leading-tight">
          "Atrevida és el somni que ens va despertar a Sant Antoni i ens va tornar a casa a Sabadell."
        </p>
        <footer class="mt-6 text-xs text-outline uppercase tracking-widest">— Marc, Héctor, Sheila & Emili</footer>
      </blockquote>
    </section>

    <!-- CTA -->
    <div class="px-6 text-center">
      <a href="/reservar" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
        Vine a conèixer-nos
        <span class="material-symbols-outlined text-[20px]" aria-hidden="true">arrow_forward</span>
      </a>
    </div>

    <!-- Mobile nav spacer -->
    <div class="h-20 md:h-0" aria-hidden="true"></div>
  </div>
</BaseLayout>
